# Firebase web config — enables cloud sync across devices.
# Copy this file to `.env.local` for local dev, and set the same variables in
# your Vercel project (Settings → Environment Variables).
#
# Get these from the Firebase console:
#   Project settings → General → Your apps → Web app → SDK setup and config.
#
# These values are NOT secrets — they ship in the frontend bundle. Access is
# protected by Firestore security rules (see firestore.rules), which lock data
# to each signed-in user. Leaving them unset simply runs the app fully local.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
